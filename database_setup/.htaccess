# Blocks the entire database_setup/ directory (install_db.php, sharek_db.sql)
# from public access. This is defense-in-depth on top of the root
# .htaccess rules, which already block these files by name/extension.
# Tries the Apache 2.4 native syntax first, falls back to the legacy
# directive for hosts without mod_authz_core -- same pattern as the root
# .htaccess, so this can't silently no-op on an older Apache build either.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order Allow,Deny
    Deny from all
</IfModule>
